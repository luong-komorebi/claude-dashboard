{
  "name": "web",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:wasm": "wasm-pack build ../wasm --target bundler --out-dir ../web/src/wasm-pkg",
    "lint": "eslint .",
